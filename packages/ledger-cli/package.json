{
	"name": "@thi.ng/ledger-cli",
	"version": "1.0.0",
	"description": "Multi-command CLI for thi.ng/ledger toolchain",
	"type": "module",
	"module": "./index.js",
	"typings": "./index.d.ts",
	"bin": "bin/ledger-cli",
	"sideEffects": false,
	"repository": {
		"type": "git",
		"url": "https://github.com/thi-ng/ledger.git"
	},
	"homepage": "https://thi.ng/",
	"author": "Karsten Schmidt (https://thi.ng)",
	"license": "Apache-2.0",
	"scripts": {
		"build": "tsc",
		"clean": "bun ../../tools/clean-package.ts cmd common",
		"doc": "typedoc --options ../../typedoc.json --out doc src/index.ts",
		"pub": "yarn npm publish --access public",
		"test": "bun test"
	},
	"dependencies": {
		"@thi.ng/api": "^8.12.1",
		"@thi.ng/args": "^2.9.2",
		"@thi.ng/compare": "^2.4.27",
		"@thi.ng/csv": "^2.5.5",
		"@thi.ng/date": "^2.7.63",
		"@thi.ng/defmulti": "^3.0.75",
		"@thi.ng/errors": "^2.5.41",
		"@thi.ng/file-io": "^2.2.8",
		"@thi.ng/lispy": "^0.4.5",
		"@thi.ng/logger": "^3.1.16",
		"@thi.ng/markdown-table": "^1.0.33",
		"@thi.ng/transducers": "^9.6.8",
		"@thi.ng/trie": "^2.0.0",
		"dotenv": "^17.2.1"
	},
	"devDependencies": {
		"@types/node": "^24.2.1",
		"typedoc": "^0.28.10",
		"typescript": "^5.9.2"
	},
	"keywords": [
		"cli",
		"typescript"
	],
	"private": true,
	"browser": {
		"process": false,
		"setTimeout": false
	},
	"files": [
		"./*.js",
		"./*.d.ts"
	],
	"exports": {
		".": {
			"default": "./index.js"
		}
	}
}
